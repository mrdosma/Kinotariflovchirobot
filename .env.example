# Telegram bot tokeni (@BotFather dan olinadi)
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID lari (vergul bilan ajratiladi)
ADMIN_IDS=123456789,987654321

# Majburiy obuna kanali (ixtiyoriy, bo'sh qoldirsa o'chiriladi)
REQUIRED_CHANNEL=@your_channel

# VIP narxi (Telegram Stars)
VIP_STARS_PRICE=50

# VIP muddati (kun)
VIP_DAYS=30

# OMDb API kaliti (ixtiyoriy, omdbapi.com dan olinadi)
OMDB_API_KEY=your_omdb_api_key
